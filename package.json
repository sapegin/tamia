{
  "name": "tamia",
  "description": "Panda CSS preset for component-driven development",
  "version": "5.0.20",
  "sideEffects": false,
  "scripts": {
    "pretest": "npm run lint",
    "test": "npm run typecheck",
    "posttest": "npm run format",
    "prepublishOnly": "npm run build",
    "lint": "eslint . --cache --fix",
    "typecheck": "tsc --noEmit",
    "build": "tsc --project tsconfig.build.json",
    "format": "prettier --log-level warn --write \"**/*.{js,cjs,mjs,ts,tsx,md,json}\"",
    "prepare": "husky"
  },
  "homepage": "https://github.com/sapegin/tamia/",
  "author": {
    "name": "Artem Sapegin",
    "url": "https://sapegin.me/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sapegin/tamia.git"
  },
  "bugs": {
    "url": "https://github.com/sapegin/tamia/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "browserslist": [
    ">1%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ],
  "peerDependencies": {
    "tailwindcss": ">=4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "^19.2.14",
    "eslint": "^9.38.0",
    "eslint-config-tamia": "^9.9.1",
    "eslint-plugin-better-tailwindcss": "4.4.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "nano-staged": "1.0.2",
    "prettier": "^3.8.3",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "4.2.2",
    "typescript": "^5.9"
  },
  "nano-staged": {
    "*.{js,cjs,mjs,ts,tsx,json,md}": "prettier --write",
    "*.{js,cjs,mjs,ts,tsx}": "eslint --cache --fix"
  },
  "dependencies": {
    "clsx": "2.1.1"
  }
}
